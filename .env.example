# Copy to .env (gitignored) and fill in. The server loads it via `--env-file`.

# Postgres connection (defaults to the docker-compose DB if unset).
DATABASE_URL=postgresql://jeopardy:jeopardy@localhost:5544/jeopardy

# Auth: HMAC secret for signing session tokens. Use a long random string in prod.
AUTH_SECRET=change-me-to-a-long-random-string
# Token lifetime in seconds (default 30 days).
AUTH_TTL_SECONDS=2592000

# Optional: smarter autopilot answer judging via OpenAI. Without a key the
# server falls back to the built-in fuzzy string matcher.
OPENAI_API_KEY=XXX
OPENAI_MODEL=gpt-4o-mini
AI_JUDGE_TIMEOUT_MS=4000

# Optional: grace period (ms) before a fully-disconnected player loses their
# seat / tears down a hosted room. Defaults to 45000.
PRESENCE_GRACE_MS=45000
